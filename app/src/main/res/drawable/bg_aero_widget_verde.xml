<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Back Glow plate with Evergreen forest green -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#F2011A0E"
                android:endColor="#F2022A16" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="#B305B26F" />
        </shape>
    </item>

    <!-- Translucent Vista/Aurora emerald top highlight -->
    <item android:bottom="45dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2C00FF88"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
