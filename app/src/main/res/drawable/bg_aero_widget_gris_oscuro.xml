<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Back Glow plate with Graphite carbon dark gray -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#F216181C"
                android:endColor="#F224272F" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="#994B5162" />
        </shape>
    </item>

    <!-- Translucent Vista/Aurora platinum/silver top highlight -->
    <item android:bottom="45dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#1EFFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
