<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Back Glow plate with Frosty Ice Sky Blue -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#F2D8E9F8"
                android:endColor="#F2BAD6F2" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="#B3005DA3" />
        </shape>
    </item>

    <!-- Translucent Vista/Aurora white ice top highlight -->
    <item android:bottom="45dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
